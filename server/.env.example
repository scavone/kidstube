# === App Identity ===
# Display name used in Telegram messages and the tvOS app
BRG_APP_NAME=KidsTube

# === Telegram ===
# Create a bot via @BotFather on Telegram to get these values
BRG_BOT_TOKEN=123456789:ABCdefGhIjKlMnOpQrStUvWxYz
BRG_ADMIN_CHAT_ID=987654321

# === Server ===
# Shared secret between tvOS app and server (generate a strong random key)
BRG_API_KEY=generate-a-strong-random-key-here
BRG_BASE_URL=https://kidstube.example.com
BRG_TIMEZONE=America/New_York
BRG_WEB_PORT=8080

# === Default Watch Limits (can be overridden per-child via Telegram) ===
BRG_DAILY_LIMIT_MINUTES=120

# === Audio Language ===
# Preferred spoken language for multi-language videos (ISO 639-1 code: en, es, ja, etc.)
# Leave empty or omit to use whatever YouTube defaults to
BRG_PREFERRED_AUDIO_LANG=en

# === Invidious ===
INVIDIOUS_DB_PASSWORD=kemal
INVIDIOUS_COMPANION_SECRET=change_me_companion
