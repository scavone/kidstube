// Secrets.xcconfig — copy to Secrets.xcconfig and fill in your values
// This file is checked into git as a template. Secrets.xcconfig is gitignored.

// Server URL (no trailing slash). Use your server's LAN IP or hostname.
BRG_SERVER_URL = http:/$()/YOUR_SERVER_IP:8080

// API key matching the server's BRG_API_KEY environment variable
BRG_API_KEY = your-api-key-here
